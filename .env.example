# Root reference — copy to apps/api/.env and apps/web/.env, apps/admin/.env

# ─── API (apps/api/.env) ───
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sk_makeup_artist?retryWrites=true&w=majority

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

CLOUDINARY_CLOUD_NAME=dgxz36qfa
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
