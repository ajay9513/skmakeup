# Production environment reference — DO NOT commit real secrets
# Copy values to Railway / Vercel dashboards

# ─── Railway (apps/api) ───
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sk_makeup_artist?retryWrites=true&w=majority

JWT_SECRET=<64-char-random>
JWT_REFRESH_SECRET=<64-char-random-different>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=dgxz36qfa
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=sk-makeup

WEB_URL=https://skmakeup.com
ADMIN_URL=https://admin.skmakeup.com
API_URL=https://api.skmakeup.com
CORS_ORIGINS=https://skmakeup.com,https://admin.skmakeup.com

COOKIE_DOMAIN=.skmakeup.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=hello@skmakeup.com

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

